# ── Anthropic ────────────────────────────────────────────────────────────────
# Required — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=incident_triage
DB_USER=postgres
DB_PASSWORD=your-strong-password-here

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=2
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── CORS (comma-separated list of allowed frontend origins) ───────────────────
# In production set this to your deployed frontend URL, e.g.:
# ALLOWED_ORIGINS=https://incidra.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── OpenTelemetry (optional) ──────────────────────────────────────────────────
OTEL_SERVICE_NAME=incidra-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
